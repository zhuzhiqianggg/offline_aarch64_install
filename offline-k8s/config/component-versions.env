# 组件版本锁定文件 - 类似于 Python 的 requirements.txt
# 此文件定义了所有组件的固定版本，确保长期稳定性
# 策略：固定版本，禁止自动升级或降级

VERSION_POLICY=fixed-reviewed
ALLOW_PRERELEASE=false
AUTO_UPGRADE=false

# Kubernetes 版本 - 基于 Sealos/Labring 官方预构建镜像可用版本
# 选择 v1.33.x 系列，经过充分测试的稳定版本
KUBERNETES_VERSION=v1.33.6

# Calico 网络插件版本
# 选择 v3.28.x 系列，与 Kubernetes 1.33 兼容
CALICO_VERSION=v3.28.1

# ingress-nginx 控制器版本
# 格式：controller-vX.Y.Z
INGRESS_NGINX_VERSION=controller-v1.15.1
INGRESS_NGINX_CHART_VERSION=4.15.1

# Kuboard 版本
# v3 是当前稳定的主要版本
KUBOARD_VERSION=v3

# Sealos 版本 - 选自 GitHub releases
SEALOS_VERSION=v5.1.1

# Helm 版本
HELM_VERSION=v3.21.2

# 版本说明
VERSION_NOTES="fixed reviewed component versions; upstream Kubernetes support window considered; no automatic downgrade or upgrade"
